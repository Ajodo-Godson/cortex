# Cortex environment configuration
# Copy this file to .env and fill in your values.

# Model to use for distillation and gardening.
# Defaults to claude-opus-4-7 if unset.
# CORTEX_MODEL=claude-opus-4-7

# Optional: override the API key for any provider.
# If unset, falls back to ANTHROPIC_API_KEY or OPENAI_API_KEY below.
# CORTEX_API_KEY=

# --- Anthropic ---
# Required when CORTEX_MODEL starts with "claude-"
ANTHROPIC_API_KEY=sk-ant-...

# Optional: custom Anthropic-compatible base URL
# ANTHROPIC_BASE_URL=

# --- OpenAI-compatible providers (NVIDIA NIM, Ollama, Azure, etc.) ---
# Required when CORTEX_MODEL is not a claude-* model
# OPENAI_API_KEY=
# CORTEX_BASE_URL=

# Examples:
#
# NVIDIA NIM:
#   CORTEX_MODEL=meta/llama-3.1-70b-instruct
#   CORTEX_API_KEY=nvapi-...
#   CORTEX_BASE_URL=https://integrate.api.nvidia.com/v1
#
# Ollama (local):
#   CORTEX_MODEL=llama3
#   CORTEX_BASE_URL=http://localhost:11434/v1
